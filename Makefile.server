.DEFAULT_GOAL := help

# ── конфиг (переопредели в команде: make -f Makefile.server vllm MODEL=…) ──
PY            ?= python3
MODEL         ?= Qwen/Qwen3-Coder-30B-A3B-Instruct
MODEL_NAME    ?= qwen3-coder
VLLM_PORT     ?= 8000
WEB_PORT      ?= 8080
ADMIN_PORT    ?= 8090
REDIS_URL     ?= redis://localhost:6379/0
VLLM_BASE_URL ?= http://localhost:$(VLLM_PORT)/v1
MAX_INFLIGHT  ?= 64

export REDIS_URL MODEL_NAME MAX_INFLIGHT ADMIN_PORT

.PHONY: help install redis vllm worker web worker-echo dev stop dashboard

help: ## показать команды
	@awk 'BEGIN{FS=":.*## "}/^[a-zA-Z_-]+:.*## /{printf "  %-13s %s\n",$$1,$$2}' $(MAKEFILE_LIST)

worker: ## воркер: форвард в vLLM
	VLLM_BASE_URL=$(VLLM_BASE_URL) $(PY) server.py

web: ## OpenAI-фронт (uvicorn)
	uvicorn web:app --host 0.0.0.0 --port $(WEB_PORT)


stop: ## погасить фоновый dev-стек
	-docker stop redis-llm
	-pkill -f "server.py"
	-pkill -f "uvicorn web:app"

dashboard: ## открыть admin-панель воркера в браузере
	open http://localhost:$(ADMIN_PORT)/
