.DEFAULT_GOAL := help

# конфиг — из .env (общий с клиентом). `make init` создаст его из .env.example.
-include .env

# ── дефолты (переопределяются .env или в команде: make worker MAX_INFLIGHT=128) ──
# Redis и vLLM уже где-то подняты — адреса берём из .env, ничего не стартуем.
VENV          ?= .venv
PY            ?= $(shell [ -x $(VENV)/bin/python ] && echo $(VENV)/bin/python || echo python3)
PIP           ?= $(VENV)/bin/pip
REDIS_URL     ?= redis://localhost:6379/0
# пусто → эхо-заглушка; иначе адрес твоего vLLM, напр. http://host:8000/v1
VLLM_BASE_URL ?=
MODEL_NAME    ?= qwen3-coder
WEB_PORT      ?= 8080
ADMIN_PORT    ?= 8090
MAX_INFLIGHT  ?= 64

# ── приватность ──
GATEWAY_CRYPTO_KEY ?=
RESP_TTL           ?= 300
REQUEST_TTL_MS     ?= 1260000
STREAM_MAXLEN      ?= 10000

# всё (включая переменные из .env) уходит в окружение server.py / web.py
export

WORKER_LOG ?= /tmp/redis-llm-worker.log
WEB_LOG    ?= /tmp/redis-llm-web.log

.PHONY: help install keygen worker web up stop restart logs dashboard

help: ## показать команды
	@awk 'BEGIN{FS=":.*## "}/^[a-zA-Z_-]+:.*## /{printf "  %-12s %s\n",$$1,$$2}' $(MAKEFILE_LIST)

install: ## venv + зависимости воркера/фронта
	python3 -m venv $(VENV)
	$(PIP) install -U pip
	$(PIP) install -r requirements.txt

keygen: ## сгенерировать GATEWAY_CRYPTO_KEY (общий ключ фронта и воркера)
	@$(PY) -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

worker: ## воркер: Redis → vLLM (эхо, если VLLM_BASE_URL пуст)
	$(PY) server.py

web: ## OpenAI-фронт (uvicorn) на :$(WEB_PORT)
	$(PY) -m uvicorn web:app --host 0.0.0.0 --port $(WEB_PORT)

up: ## воркер + фронт в фоне (Redis/vLLM уже подняты, адреса в .env)
	@nohup $(PY) server.py > $(WORKER_LOG) 2>&1 &
	@nohup $(PY) -m uvicorn web:app --host 0.0.0.0 --port $(WEB_PORT) > $(WEB_LOG) 2>&1 &
	@sleep 2
	@echo "фронт    http://localhost:$(WEB_PORT)/v1   ·   admin http://localhost:$(ADMIN_PORT)/"
	@if [ -n "$$VLLM_BASE_URL" ]; then echo "upstream $$VLLM_BASE_URL"; else echo "upstream ЭХО (VLLM_BASE_URL пуст)"; fi
	@if [ -n "$$GATEWAY_CRYPTO_KEY" ]; then echo "шифрование Redis: ВКЛ"; else echo "шифрование Redis: ВЫКЛ — make keygen"; fi
	@echo "логи     $(WORKER_LOG)  ·  $(WEB_LOG)   ·   стоп: make -f Makefile.server stop"

stop: ## погасить воркер и фронт
	-pkill -f "server.py"
	-pkill -f "uvicorn web:app"
	-rm -f $(WORKER_LOG) $(WEB_LOG)

restart: stop up ## перезапустить стек

dashboard: ## открыть admin-панель воркера в браузере
	open http://localhost:$(ADMIN_PORT)/

logs: ## хвост логов воркера/фронта
	@tail -n 40 -F $(WORKER_LOG) $(WEB_LOG)
