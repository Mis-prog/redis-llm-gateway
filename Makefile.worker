.DEFAULT_GOAL := help

# Воркерная часть: server.py (Redis → vLLM) и admin.py (FastAPI-дашборд).
# Запускается на машине с доступом к vLLM. Конфиг — из .env (общий с клиентом,
# см. .env.example). Redis и vLLM считаем уже поднятыми — адреса берём из .env.
-include .env

# ── дефолты (переопредели в .env или в команде: make worker MAX_INFLIGHT=128) ──
VENV       ?= .venv
PY         ?= $(shell [ -x $(VENV)/bin/python ] && echo $(VENV)/bin/python || echo python3)
PIP        ?= $(VENV)/bin/pip
ADMIN_HOST ?= 127.0.0.1
ADMIN_PORT ?= 8090

# всё (включая переменные из .env) уходит в окружение server.py / admin.py
export

WORKER_LOG ?= /tmp/redis-llm-worker.log
ADMIN_LOG  ?= /tmp/redis-llm-admin.log

.PHONY: help install keygen worker admin up stop restart logs dashboard

help: ## показать команды
	@awk 'BEGIN{FS=":.*## "}/^[a-zA-Z_-]+:.*## /{printf "  %-12s %s\n",$$1,$$2}' $(MAKEFILE_LIST)

install: ## venv + зависимости воркера/admin
	python3 -m venv $(VENV)
	$(PIP) install -U pip
	$(PIP) install -r requirements.txt

keygen: ## сгенерировать GATEWAY_CRYPTO_KEY (общий ключ фронта и воркера)
	@$(PY) -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

worker: ## воркер: Redis → vLLM (эхо, если VLLM_BASE_URL пуст)
	$(PY) server.py

admin: ## admin-дашборд (FastAPI/uvicorn) на :$(ADMIN_PORT)
	$(PY) -m uvicorn admin:app --host $(ADMIN_HOST) --port $(ADMIN_PORT)

up: ## воркер + admin в фоне (Redis/vLLM уже подняты, адреса в .env)
	@nohup $(PY) server.py > $(WORKER_LOG) 2>&1 &
	@nohup $(PY) -m uvicorn admin:app --host $(ADMIN_HOST) --port $(ADMIN_PORT) > $(ADMIN_LOG) 2>&1 &
	@sleep 2
	@echo "воркер   логи $(WORKER_LOG)   ·   admin http://$(ADMIN_HOST):$(ADMIN_PORT)/"
	@if [ -n "$$VLLM_BASE_URL" ]; then echo "upstream $$VLLM_BASE_URL"; else echo "upstream ЭХО (VLLM_BASE_URL пуст)"; fi
	@if [ -n "$$GATEWAY_CRYPTO_KEY" ]; then echo "шифрование Redis: ВКЛ"; else echo "шифрование Redis: ВЫКЛ — make keygen"; fi
	@if [ -n "$$KEY_PREFIX" ]; then echo "неймспейс ключей: $$KEY_PREFIX"; else echo "неймспейс: ПУСТО — на ОБЩЕМ Redis задай KEY_PREFIX в .env"; fi
	@echo "стоп: make -f Makefile.worker stop"

stop: ## погасить воркер и admin
	-pkill -f "server.py"
	-pkill -f "uvicorn admin:app"
	-rm -f $(WORKER_LOG) $(ADMIN_LOG)

restart: stop up ## перезапустить воркер + admin

dashboard: ## открыть admin-дашборд в браузере
	open http://$(ADMIN_HOST):$(ADMIN_PORT)/

logs: ## хвост логов воркера/admin
	@tail -n 40 -F $(WORKER_LOG) $(ADMIN_LOG)
