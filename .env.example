# ───────────────────────────────────────────────────────────────────────────
# redis-llm-gateway — единый конфиг для сервера и клиента.
# Скопируй в .env (`make init`) и правь под себя. Файл читают Makefile'ы и
# экспортируют переменные в server.py / web.py / client.py.
# Формат строго: KEY=VALUE — без пробелов вокруг =, без кавычек, без коммента
# в той же строке (комментарий = отдельная строка с #).
# Redis и vLLM считаем уже поднятыми — здесь только их адреса.
# ───────────────────────────────────────────────────────────────────────────

# ── общее (сервер + клиент) ──
# адрес уже работающего Redis (можно с авторизацией: redis://:pass@host:6379/0)
REDIS_URL=redis://localhost:6379/0
# имя модели в API: что шлёт клиент и что отдаёт фронт в /v1/models
MODEL_NAME=qwen3-coder

# ── upstream vLLM (только сервер) ──
# Пусто → воркер отвечает ЭХО-заглушкой (быстрая проверка тракта).
# Иначе адрес уже работающего vLLM, напр.: http://localhost:8000/v1
VLLM_BASE_URL=
VLLM_API_KEY=EMPTY
# сколько запросов воркер держит разом (~ --max-num-seqs у vLLM)
MAX_INFLIGHT=64
# таймаут запроса к vLLM, сек
HTTP_TIMEOUT=600

# ── фронт (web.py) ──
WEB_PORT=8080
# пусто → без авторизации; иначе клиент шлёт этот ключ как Bearer
GATEWAY_API_KEY=
# сколько фронт ждёт ответ воркера, сек
REPLY_TIMEOUT=300

# ── admin-панель: admin.py (отдельный FastAPI-процесс) ──
ADMIN_HOST=127.0.0.1
# порт uvicorn для admin.py
ADMIN_PORT=8090
# период публикации метрик воркером (их читает admin.py), сек
HEARTBEAT_SEC=10

# ── приватность / следы в Redis ──
# Префикс ВСЕХ ключей в Redis — изоляция на ОБЩЕМ Redis (БД делят с другими).
# ПУСТО → общие имена (llm:requests…): будешь читать/резать ЧУЖИЕ сообщения
# (отсюда «invalid token»!) и мешать соседям. Задай УНИКАЛЬНОЕ значение с
# разделителем на конце, напр.:  KEY_PREFIX=mihail:
KEY_PREFIX=
# Общий ключ шифрования (одинаковый у фронта и воркера). Сгенерить: make keygen
# Пусто → payload'ы лежат в Redis ОТКРЫТЫМ текстом.
GATEWAY_CRYPTO_KEY=
# TTL ответов/стрим-чанков, сек. Приватнее: 30
RESP_TTL=300
# режем свой стрим запросов по возрасту, мс. Приватнее: 60000 (= 1 мин)
REQUEST_TTL_MS=1260000
# потолок числа запросов в очереди. Приватнее: 100
STREAM_MAXLEN=10000

# ── клиент (client.py / Makefile.client), запускается на ДРУГОЙ машине ──
# адрес шлюза-сервера, куда ходит клиент (замени localhost на хост сервера)
GATEWAY=http://localhost:8080
PROMPT=Привет, кто ты?

# ── логи ──
# DEBUG / INFO / WARNING
LOG_LEVEL=INFO
