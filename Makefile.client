.DEFAULT_GOAL := help

# Клиентская часть: OpenAI-фронт web.py (шлюз) + готовые проверки тракта (curl/SDK).
# Запускается на машине у пользователя. Конфиг — из .env (общий с воркером,
# см. .env.example).
-include .env
export

# ── дефолты (переопредели: make chat PROMPT="…" GATEWAY=…) ──
VENV       ?= .venv
PY         ?= $(shell [ -x $(VENV)/bin/python ] && echo $(VENV)/bin/python || echo python3)
PIP        ?= $(VENV)/bin/pip
WEB_PORT   ?= 8080
GATEWAY    ?= http://localhost:$(WEB_PORT)
MODEL_NAME ?= qwen3-coder
PROMPT     ?= Привет, кто ты?

WEB_LOG    ?= /tmp/redis-llm-web.log

.PHONY: help install web up stop restart logs health models chat tools stream ask smoke

help: ## показать команды
	@awk 'BEGIN{FS=":.*## "}/^[a-zA-Z_-]+:.*## /{printf "  %-13s %s\n",$$1,$$2}' $(MAKEFILE_LIST)

install: ## venv + зависимости фронта (fastapi/uvicorn/redis/…) + openai SDK
	python3 -m venv $(VENV)
	$(PIP) install -U pip
	$(PIP) install -r requirements.txt openai

web: ## OpenAI-фронт web.py (uvicorn) на :$(WEB_PORT)
	$(PY) -m uvicorn web:app --host 0.0.0.0 --port $(WEB_PORT)

up: ## фронт web.py в фоне
	@nohup $(PY) -m uvicorn web:app --host 0.0.0.0 --port $(WEB_PORT) > $(WEB_LOG) 2>&1 &
	@sleep 2
	@echo "фронт http://localhost:$(WEB_PORT)/v1   ·   логи $(WEB_LOG)   ·   стоп: make -f Makefile.client stop"

stop: ## погасить фронт
	-pkill -f "uvicorn web:app"
	-rm -f $(WEB_LOG)

restart: stop up ## перезапустить фронт

logs: ## хвост логов фронта
	@tail -n 40 -F $(WEB_LOG)

health: ## проверка живости шлюза
	curl -s $(GATEWAY)/health && echo

models: ## список моделей
	curl -s $(GATEWAY)/v1/models | $(PY) -m json.tool

chat: ## обычный запрос (PROMPT=…)
	curl -s $(GATEWAY)/v1/chat/completions -H 'Content-Type: application/json' \
	  -d '{"model":"$(MODEL_NAME)","messages":[{"role":"user","content":"$(PROMPT)"}]}' \
	  | $(PY) -m json.tool

tools: ## запрос с инструментом (function calling)
	curl -s $(GATEWAY)/v1/chat/completions -H 'Content-Type: application/json' \
	  -d '{"model":"$(MODEL_NAME)","messages":[{"role":"user","content":"Погода в Париже?"}],"tools":[{"type":"function","function":{"name":"get_weather","description":"Текущая погода","parameters":{"type":"object","properties":{"city":{"type":"string"}},"required":["city"]}}}],"tool_choice":"auto"}' \
	  | $(PY) -m json.tool

stream: ## стриминговый запрос (SSE)
	curl -N -s $(GATEWAY)/v1/chat/completions -H 'Content-Type: application/json' \
	  -d '{"model":"$(MODEL_NAME)","messages":[{"role":"user","content":"$(PROMPT)"}],"stream":true}'

ask: ## запрос через OpenAI SDK (python)
	$(PY) -c "from openai import OpenAI; c=OpenAI(base_url='$(GATEWAY)/v1', api_key='EMPTY'); print(c.chat.completions.create(model='$(MODEL_NAME)', messages=[{'role':'user','content':'$(PROMPT)'}]).choices[0].message.content)"

smoke: ## быстрый прогон: health + models + chat + stream
	@$(MAKE) -s -f Makefile.client health
	@$(MAKE) -s -f Makefile.client models
	@$(MAKE) -s -f Makefile.client chat
	@$(MAKE) -s -f Makefile.client stream
	@echo
